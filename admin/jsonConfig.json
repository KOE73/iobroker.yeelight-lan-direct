{
  "i18n": true,
  "type": "panel",
  "items": {
    "_discoveryHeader": {
      "type": "header",
      "size": 2,
      "text": "Discovery"
    },
    "_discoverMode": {
      "type": "select",
      "label": "Discovery mode",
      "sm": 12,
      "md": 4,
      "default": "all",
      "options": [
        { "value": "all", "label": "All interfaces" },
        { "value": "auto", "label": "Auto" },
        { "value": "manual", "label": "Manual IP" }
      ]
    },
    "_discoverTarget": {
      "type": "text",
      "label": "Manual IP",
      "sm": 12,
      "md": 4,
      "placeholder": "192.168.1.50",
      "hidden": "data._discoverMode !== 'manual'"
    },
    "_discover": {
      "type": "sendTo",
      "label": "Discover",
      "variant": "contained",
      "icon": "search",
      "sm": 12,
      "md": 4,
      "command": "discover",
      "jsonData": "{\"mode\": \"${data._discoverMode}\", \"targetAddress\": \"${data._discoverTarget}\", \"timeoutMs\": 4000}",
      "useNative": true,
      "result": {
        "found": "Found or updated devices"
      }
    },
    "_devicesHeader": {
      "type": "header",
      "size": 2,
      "text": "Devices"
    },
    "devices": {
      "type": "table",
      "noDelete": false,
      "items": [
        {
          "type": "checkbox",
          "attr": "enabled",
          "title": "Enabled",
          "width": "8%",
          "default": true
        },
        {
          "type": "text",
          "attr": "name",
          "title": "Name",
          "width": "22%"
        },
        {
          "type": "text",
          "attr": "ip",
          "title": "IP Address",
          "width": "20%"
        },
        {
          "type": "number",
          "attr": "port",
          "title": "Port",
          "width": "10%",
          "default": 55443
        },
        {
          "type": "text",
          "attr": "model",
          "title": "Model",
          "width": "15%"
        },
        {
          "type": "text",
          "attr": "id",
          "title": "Device ID",
          "width": "25%"
        }
      ]
    }
  }
}
